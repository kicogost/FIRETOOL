# Copy this file to ".env.local" and fill in the values to use Supabase.
# If DATABASE_URL is empty/absent, the app runs on local PGlite (no setup needed).

# Supabase Postgres connection string.
# Supabase dashboard → Project → "Connect" → ORMs/Drizzle (or "Connection string").
# Use the "Session pooler" / "Transaction pooler" URI and put your DB password in.
# Example shape:
#   postgresql://postgres.abcdxyz:YOUR-PASSWORD@aws-0-eu-west-1.pooler.supabase.com:6543/postgres
DATABASE_URL=

# Supabase project API (for the client SDK / Auth in a later step).
# Supabase dashboard → Project Settings → API.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
